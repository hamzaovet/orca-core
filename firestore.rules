rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Collection
    match /users/{userId} {
      // User can read their own profile. Admin can read all.
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Only admin can write to users (auth handles creation in signup)
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // Service Requests Collection
    match /service_requests/{requestId} {
      // User can create. User can read own. Admin can read all.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      // Admin can update status
      allow update: if request.auth != null && isAdmin();
      // Admin can delete
      allow delete: if request.auth != null && isAdmin();
    }

    // Portfolio Projects Collection
    match /portfolio_projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Projects Collection
    match /projects/{projectId} {
      // User can read their own projects, Admin can read/write all
      allow read: if request.auth != null && (request.auth.uid == resource.data.clientId || isAdmin());
      allow write: if request.auth != null && isAdmin();
    }

    // Messages Collection
    match /messages/{messageId} {
      // Need to ideally verify if user is part of projectId, but for simplicity assuming if auth'd they can write.
      // A stronger rule would query the project clientId, but reads allow checking senderId.
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.senderId;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // Files Collection
    match /files/{fileId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uploadedBy;
      allow update, delete: if request.auth != null && isAdmin();
    }

    // Invoices Collection
    match /invoices/{invoiceId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.clientId || isAdmin());
      allow write: if request.auth != null && isAdmin();
    }

    // AI Websites Collection
    match /ai_websites/{websiteId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Subscriptions Collection
    match /subscriptions/{subscriptionId} {
      allow read, write: if request.auth != null && (request.auth.uid == subscriptionId || isAdmin());
    }

    // AI Funnels Collection
    match /ai_funnels/{funnelId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Helper functions
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
